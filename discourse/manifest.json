{
    "name": "Discourse",
    "code": "discourse",
    "type": "application",
    "version": "3.5",
    "description": "Build an online community with modern discussion forums, categories, and user engagement features.",
    "url": "https://www.discourse.org",
    "documentation": "https://meta.discourse.org/docs",
    "category": "community",
    "tenancy": [
        "single-tenant"
    ],
    "components": [
        {
            "name": "discourse",
            "type": "deployment",
            "image": "bitnamilegacy/discourse:3.5.0",
            "ports": [
                {
                    "port": 3000,
                    "protocol": "TCP",
                    "ingress": true
                }
            ],
            "volumes": [
                "data"
            ]
        },
        {
            "name": "postgresql",
            "type": "deployment",
            "image": "pgvector/pgvector:pg17",
            "database": "postgresql",
            "ports": [
                {
                    "port": 5432,
                    "protocol": "TCP",
                    "ingress": false
                }
            ],
            "volumes": [
                "database"
            ]
        },
        {
            "name": "redis",
            "type": "deployment",
            "image": "bitnamilegacy/redis:8.2",
            "ports": [
                {
                    "port": 6379,
                    "protocol": "TCP",
                    "ingress": false
                }
            ],
            "volumes": []
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Web UI"
            }
        ],
        "host_ports": [],
        "websocket": false
    },
    "volumes": [
        {
            "local_path": "data",
            "container_path": "/bitnami/discourse",
            "description": "Discourse plugins, public/backups, public/uploads (per DISCOURSE_DATA_TO_PERSIST default)"
        },
        {
            "local_path": "database",
            "container_path": "/var/lib/postgresql/data",
            "description": "PostgreSQL data directory (pgvector image is based on the official postgres image)"
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.50",
            "memory": "1Gi",
            "storage": "15Gi"
        },
        "recommended": {
            "cpu": "1.00",
            "memory": "2Gi",
            "storage": "30Gi"
        }
    },
    "health_check": {
        "path": "/srv/status",
        "port": 3000,
        "initial_delay_seconds": 180,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "ingress.domain",
            "label": "Domain",
            "type": "string",
            "required": true
        },
        {
            "key": "discourse.adminEmail",
            "label": "Admin Email",
            "type": "string",
            "required": true
        },
        {
            "key": "discourse.adminPassword",
            "label": "Admin Password",
            "type": "secret",
            "required": true
        },
        {
            "key": "discourse.siteName",
            "label": "Site Name",
            "type": "string",
            "default": "My Discourse Forum",
            "required": true
        },
        {
            "key": "postgresql.storageSize",
            "label": "Database Storage Size",
            "type": "string",
            "default": "10Gi"
        },
        {
            "key": "discourseData.storageSize",
            "label": "Application Storage Size",
            "type": "string",
            "default": "20Gi"
        },
        {
            "key": "smtp.host",
            "label": "SMTP Server",
            "type": "string",
            "required": true
        },
        {
            "key": "smtp.port",
            "label": "SMTP Port",
            "type": "integer",
            "default": 587,
            "required": true
        },
        {
            "key": "smtp.username",
            "label": "SMTP Username",
            "type": "string",
            "required": true
        },
        {
            "key": "smtp.password",
            "label": "SMTP Password",
            "type": "secret",
            "required": true
        }
    ],
    "tags": [
        "forum",
        "community",
        "discourse",
        "discussion"
    ],
    "supportedVersions": [
        {
            "version": "3.4",
            "components": [
                {
                    "name": "discourse",
                    "image": "bitnamilegacy/discourse:3.4.7"
                }
            ],
            "eolDate": "2026-09-30",
            "isDefault": false
        },
        {
            "version": "3.5",
            "components": [
                {
                    "name": "discourse",
                    "image": "bitnamilegacy/discourse:3.5.0"
                }
            ],
            "upgradeFrom": [
                "3.4"
            ],
            "isDefault": true
        }
    ],
    "env_vars": {
        "generated": [
            "POSTGRES_PASSWORD",
            "DISCOURSE_PASSWORD"
        ],
        "fixed": {
            "POSTGRES_DB": "bitnami_discourse",
            "POSTGRES_USER": "bn_discourse",
            "DISCOURSE_DATABASE_HOST": "{{SERVICE:postgresql}}",
            "DISCOURSE_DATABASE_PORT_NUMBER": "5432",
            "DISCOURSE_DATABASE_NAME": "bitnami_discourse",
            "DISCOURSE_DATABASE_USER": "bn_discourse",
            "DISCOURSE_DATABASE_PASSWORD": "{{ENV:POSTGRES_PASSWORD}}",
            "DISCOURSE_REDIS_HOST": "{{SERVICE:redis}}",
            "DISCOURSE_REDIS_PORT_NUMBER": "6379",
            "DISCOURSE_HOST": "localhost",
            "DISCOURSE_USERNAME": "admin",
            "DISCOURSE_EMAIL": "admin@example.com",
            "DISCOURSE_SITE_NAME": "My Discourse Forum",
            "DISCOURSE_PRECOMPILE_ASSETS": "no",
            "ALLOW_EMPTY_PASSWORD": "yes"
        },
        "configurable": [
            "DISCOURSE_HOST",
            "DISCOURSE_EMAIL",
            "DISCOURSE_SITE_NAME",
            "DISCOURSE_SMTP_HOST",
            "DISCOURSE_SMTP_PORT_NUMBER",
            "DISCOURSE_SMTP_USER",
            "DISCOURSE_SMTP_PASSWORD"
        ]
    }
}
