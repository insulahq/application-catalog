{
    "name": "Invoice Ninja",
    "code": "invoiceninja",
    "type": "application",
    "version": "5",
    "description": "Create professional invoices, track payments, manage expenses, and accept online payments.",
    "url": "https://invoiceninja.com",
    "documentation": "https://invoiceninja.github.io",
    "category": "ecommerce",
    "tenancy": [
        "single-tenant"
    ],
    "components": [
        {
            "name": "invoiceninja",
            "type": "deployment",
            "image": "invoiceninja/invoiceninja-debian:5",
            "ports": [
                {
                    "port": 9000,
                    "protocol": "TCP"
                }
            ],
            "volumes": [
                "public",
                "storage"
            ],
            "resourceShare": {
                "weight": 50,
                "minCpu": "100m",
                "minMemory": "192Mi"
            }
        },
        {
            "name": "nginx",
            "type": "deployment",
            "image": "nginx:1.27-alpine",
            "command": [
                "sh",
                "-c",
                "cat > /etc/nginx/conf.d/default.conf <<'CONF'\nserver {\n    listen 80 default_server;\n    server_name _;\n    root /var/www/html/public;\n    index index.php;\n    client_max_body_size 50M;\n    location / { try_files $uri $uri/ /index.php?$query_string; }\n    location ~ \\.php$ {\n        fastcgi_pass FPM_HOST:9000;\n        fastcgi_index index.php;\n        include /etc/nginx/fastcgi_params;\n        fastcgi_param SCRIPT_FILENAME /var/www/html/public$fastcgi_script_name;\n        fastcgi_read_timeout 300;\n    }\n    location ~ /\\.ht { deny all; }\n}\nCONF\nsed -i \"s|FPM_HOST|${FPM_HOST}|g\" /etc/nginx/conf.d/default.conf\nexec nginx -g 'daemon off;'\n"
            ],
            "ports": [
                {
                    "port": 80,
                    "protocol": "TCP",
                    "ingress": true
                }
            ],
            "volumes": [
                "public"
            ],
            "resources": {
                "cpu": "100m",
                "memory": "64Mi"
            },
            "resourceShare": {
                "weight": 10,
                "minCpu": "30m",
                "minMemory": "32Mi"
            }
        },
        {
            "name": "mariadb",
            "type": "deployment",
            "image": "mariadb:11.8",
            "ports": [
                {
                    "port": 3306,
                    "protocol": "TCP"
                }
            ],
            "volumes": [
                "database"
            ],
            "resourceShare": {
                "weight": 40,
                "minCpu": "100m",
                "minMemory": "192Mi"
            }
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 80,
                "protocol": "TCP",
                "tls": true,
                "description": "Invoice Ninja web interface"
            }
        ]
    },
    "volumes": [
        {
            "local_path": "public",
            "container_path": "/var/www/html/public",
            "description": "Public assets and generated files"
        },
        {
            "local_path": "storage",
            "container_path": "/var/www/html/storage",
            "description": "Application storage (invoices, logs, cache)"
        },
        {
            "local_path": "database",
            "container_path": "/var/lib/mysql",
            "description": "MariaDB database storage"
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.25",
            "memory": "256Mi",
            "storage": "5Gi"
        },
        "recommended": {
            "cpu": "0.50",
            "memory": "512Mi",
            "storage": "15Gi"
        }
    },
    "health_check": {
        "path": "/health",
        "port": 80,
        "initial_delay_seconds": 60,
        "period_seconds": 10
    },
    "parameters": [
        {
            "key": "domain",
            "label": "Domain",
            "type": "string",
            "required": true,
            "description": "Fully qualified domain name for Invoice Ninja"
        },
        {
            "key": "app.url",
            "label": "Application URL",
            "type": "string",
            "required": true,
            "description": "Full URL including protocol (e.g., https://invoices.example.com)"
        },
        {
            "key": "app.key",
            "label": "Application Key",
            "type": "secret",
            "required": true,
            "description": "Laravel application encryption key (base64:...)"
        },
        {
            "key": "admin.email",
            "label": "Admin Email",
            "type": "string",
            "required": true,
            "description": "Initial admin user email address"
        },
        {
            "key": "admin.password",
            "label": "Admin Password",
            "type": "secret",
            "required": true,
            "description": "Initial admin user password"
        },
        {
            "key": "db.password",
            "label": "Database Password",
            "type": "secret",
            "required": true,
            "description": "MariaDB database password"
        },
        {
            "key": "smtp.host",
            "label": "SMTP Host",
            "type": "string",
            "description": "SMTP server hostname"
        },
        {
            "key": "smtp.port",
            "label": "SMTP Port",
            "type": "integer",
            "default": 587,
            "description": "SMTP server port"
        },
        {
            "key": "smtp.username",
            "label": "SMTP Username",
            "type": "string",
            "description": "SMTP authentication username"
        },
        {
            "key": "smtp.password",
            "label": "SMTP Password",
            "type": "secret",
            "description": "SMTP authentication password"
        }
    ],
    "tags": [
        "invoicing",
        "billing",
        "invoiceninja",
        "accounting"
    ],
    "supportedVersions": [
        {
            "version": "4",
            "components": [
                {
                    "name": "invoiceninja",
                    "image": "invoiceninja/invoiceninja-debian:4"
                }
            ],
            "eolDate": "2026-09-30",
            "migrationNotes": "Invoice Ninja v4 reaches end-of-life September 2026. Upgrade to v5.",
            "isDefault": false
        },
        {
            "version": "5",
            "components": [
                {
                    "name": "invoiceninja",
                    "image": "invoiceninja/invoiceninja-debian:5"
                }
            ],
            "upgradeFrom": [
                "4"
            ],
            "breakingChanges": "Major version upgrade from Invoice Ninja v4 to v5. Data migration required.",
            "isDefault": true
        }
    ],
    "env_vars": {
        "generated": [
            "MARIADB_ROOT_PASSWORD",
            "INVOICENINJA_DB_PASSWORD",
            "APP_KEY",
            "IN_PASSWORD"
        ],
        "fixed": {
            "MARIADB_DATABASE": "invoiceninja",
            "MARIADB_USER": "invoiceninja",
            "MARIADB_PASSWORD": "{{ENV:INVOICENINJA_DB_PASSWORD}}",
            "DB_TYPE": "mysql",
            "DB_HOST": "{{SERVICE:mariadb}}",
            "DB_DATABASE": "invoiceninja",
            "DB_USERNAME": "invoiceninja",
            "DB_PASSWORD": "{{ENV:INVOICENINJA_DB_PASSWORD}}",
            "DB_STRICT": "false",
            "APP_ENV": "production",
            "APP_URL": "http://localhost",
            "APP_DEBUG": "false",
            "REQUIRE_HTTPS": "false",
            "APP_CIPHER": "AES-256-CBC",
            "IN_USER_EMAIL": "admin@example.com",
            "FPM_HOST": "{{SERVICE:invoiceninja}}"
        },
        "configurable": [
            "APP_URL",
            "APP_DEBUG",
            "REQUIRE_HTTPS"
        ]
    }
}
