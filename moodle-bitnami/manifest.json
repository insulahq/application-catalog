{
    "name": "Moodle",
    "code": "moodle-bitnami",
    "type": "application",
    "version": "5.2",
    "description": "Run online courses, quizzes, and training programs with this full-featured learning platform. Built on erseco/alpine-moodle (Alpine + PHP 8.3 + nginx) with PostgreSQL.",
    "url": "https://moodle.org",
    "documentation": "https://docs.moodle.org",
    "category": "education",
    "tenancy": [
        "single-tenant"
    ],
    "components": [
        {
            "name": "moodle",
            "type": "deployment",
            "image": "erseco/alpine-moodle:v5.2.0",
            "ports": [
                {
                    "port": 8080,
                    "protocol": "TCP",
                    "ingress": true
                }
            ],
            "volumes": [
                "moodledata"
            ]
        },
        {
            "name": "postgresql",
            "type": "deployment",
            "image": "postgres:18-alpine",
            "database": "postgresql",
            "ports": [
                {
                    "port": 5432,
                    "protocol": "TCP",
                    "ingress": false
                }
            ],
            "volumes": [
                "database"
            ]
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Moodle web interface"
            }
        ],
        "host_ports": [],
        "websocket": false,
        "notes": "Moodle supports large file uploads (assignments, SCORM packages). Ingress proxy-body-size should be set to at least 256M; matching nginx upload_max_filesize/post_max_size already at 50M in the image."
    },
    "volumes": [
        {
            "local_path": "moodledata",
            "container_path": "/var/www/moodledata",
            "description": "Moodle data directory (filedir, cache, sessions)"
        },
        {
            "local_path": "database",
            "container_path": "/var/lib/postgresql",
            "description": "PostgreSQL data directory (pg18-alpine inits at /var/lib/postgresql/18/docker inside this mount)"
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.50",
            "memory": "1Gi",
            "storage": "20Gi"
        },
        "recommended": {
            "cpu": "1.00",
            "memory": "2Gi",
            "storage": "50Gi"
        }
    },
    "health_check": {
        "path": "/login/index.php",
        "port": 8080,
        "initial_delay_seconds": 180,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "moodle.username",
            "label": "Admin Username",
            "type": "string",
            "default": "admin",
            "required": true
        },
        {
            "key": "moodle.password",
            "label": "Admin Password",
            "type": "secret",
            "required": true
        },
        {
            "key": "moodle.email",
            "label": "Admin Email",
            "type": "string",
            "required": true
        },
        {
            "key": "moodle.siteName",
            "label": "Site Name",
            "type": "string",
            "default": "Moodle",
            "required": false
        },
        {
            "key": "moodle.dataStorageSize",
            "label": "Moodle Data Storage Size",
            "type": "string",
            "default": "20Gi"
        },
        {
            "key": "postgresql.storageSize",
            "label": "Database Storage Size",
            "type": "string",
            "default": "10Gi"
        }
    ],
    "tags": [
        "education",
        "lms",
        "elearning",
        "courses",
        "moodle"
    ],
    "supportedVersions": [
        {
            "version": "4.5",
            "components": [
                {
                    "name": "moodle",
                    "image": "erseco/alpine-moodle:v4.5.11"
                }
            ],
            "eolDate": "2026-09-30",
            "isDefault": false
        },
        {
            "version": "5.0",
            "components": [
                {
                    "name": "moodle",
                    "image": "erseco/alpine-moodle:v5.0.7"
                }
            ],
            "isDefault": false
        },
        {
            "version": "5.1",
            "components": [
                {
                    "name": "moodle",
                    "image": "erseco/alpine-moodle:v5.1.4"
                }
            ],
            "isDefault": false
        },
        {
            "version": "5.2",
            "components": [
                {
                    "name": "moodle",
                    "image": "erseco/alpine-moodle:v5.2.0"
                }
            ],
            "upgradeFrom": [
                "4.5",
                "5.0",
                "5.1"
            ],
            "isDefault": true
        }
    ],
    "env_vars": {
        "generated": [
            "POSTGRES_PASSWORD",
            "MOODLE_PASSWORD"
        ],
        "fixed": {
            "POSTGRES_DB": "moodle",
            "POSTGRES_USER": "moodle",
            "DB_TYPE": "pgsql",
            "DB_HOST": "{{SERVICE:postgresql}}",
            "DB_PORT": "5432",
            "DB_NAME": "moodle",
            "DB_USER": "moodle",
            "DB_PASS": "{{ENV:POSTGRES_PASSWORD}}",
            "MOODLE_USERNAME": "admin",
            "MOODLE_EMAIL": "admin@example.com",
            "MOODLE_SITENAME": "Moodle",
            "SITE_URL": "http://localhost:8080",
            "SSLPROXY": "true",
            "REVERSEPROXY": "false",
            "AUTO_UPDATE_MOODLE": "true",
            "RUN_CRON_TASKS": "true"
        },
        "configurable": [
            "MOODLE_EMAIL",
            "MOODLE_SITENAME",
            "SITE_URL",
            "DEBUG"
        ]
    }
}
